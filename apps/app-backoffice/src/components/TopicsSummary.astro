---
import type { TopicScore } from "@/lib/topics";

interface Props {
  topics: TopicScore[];
}

const { topics } = Astro.props;
---

<section class="bg-card rounded-xl border border-border p-5">
  <div class="flex items-center justify-between mb-4">
    <h2 class="text-sm font-semibold text-text-primary uppercase tracking-wider">Topics</h2>
    <a href="/topics" class="text-sm text-brand hover:text-brand-hover transition-colors">
      Ver todos &rarr;
    </a>
  </div>
  {topics.length > 0 ? (
    <div class="space-y-3">
      {topics.map((topic) => (
        <div>
          <div class="flex items-center justify-between mb-1">
            <span class="text-sm font-medium text-text-primary">{topic.label}</span>
            <span class="text-xs font-mono tabular-nums text-text-muted">{Math.round(topic.normalizedScore)}%</span>
          </div>
          <div class="h-2.5 rounded-full bg-surface-raised overflow-hidden">
            <div
              class="h-full rounded-full transition-all duration-500"
              style={`width: ${Math.max(topic.normalizedScore, 3)}%; background: ${topic.color};`}
            />
          </div>
        </div>
      ))}
    </div>
  ) : (
    <p class="text-sm text-text-muted">Sin datos de topics. Ejecutá <code class="bg-surface-raised px-1.5 py-0.5 rounded text-xs">analyze_topics.py</code> primero.</p>
  )}
</section>
