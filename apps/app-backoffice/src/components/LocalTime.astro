---
interface Props {
  utc: string | Date | null | undefined;
  fmt?: "date" | "time" | "datetime";
  class?: string;
}

const { utc: rawUtc, fmt = "datetime", class: className } = Astro.props;

// Normalize: PG returns Date objects, SQLite returned strings
const utc = rawUtc instanceof Date ? rawUtc.toISOString() : rawUtc;

// Build a legible UTC fallback
let fallback = "—";
if (utc) {
  const [datePart, timePart] = utc.split("T");
  if (fmt === "date") fallback = datePart ?? utc;
  else if (fmt === "time") fallback = timePart?.slice(0, 5) ?? utc;
  else fallback = timePart ? `${datePart} ${timePart.slice(0, 5)}` : datePart ?? utc;
}
---

{utc ? (
  <time data-utc={utc} data-fmt={fmt} class={className}>{fallback}</time>
) : (
  <span class={className}>—</span>
)}
