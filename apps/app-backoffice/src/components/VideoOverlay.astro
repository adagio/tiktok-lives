---
---

<dialog id="video-overlay" class="video-overlay">
  <div class="video-overlay__card">
    <header class="video-overlay__header">
      <div class="video-overlay__meta">
        <span id="overlay-username" class="video-overlay__username"></span>
        <span id="overlay-query" class="video-overlay__query"></span>
        <span id="overlay-duration" class="video-overlay__duration"></span>
      </div>
      <button type="button" id="overlay-close" class="video-overlay__close" aria-label="Cerrar">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="w-5 h-5" aria-hidden="true">
          <path d="M6.28 5.22a.75.75 0 00-1.06 1.06L8.94 10l-3.72 3.72a.75.75 0 101.06 1.06L10 11.06l3.72 3.72a.75.75 0 101.06-1.06L11.06 10l3.72-3.72a.75.75 0 00-1.06-1.06L10 8.94 6.28 5.22z" />
        </svg>
      </button>
    </header>

    <video id="overlay-video" controls playsinline preload="metadata" class="video-overlay__video"></video>

    <p id="overlay-text" class="video-overlay__text"></p>
  </div>
</dialog>

<style>
  .video-overlay {
    border: none;
    background: transparent;
    padding: 0;
    max-width: 100vw;
    max-height: 100vh;
    width: 100%;
    height: 100%;
    overflow: hidden;
  }

  .video-overlay::backdrop {
    background: rgba(0, 0, 0, 0.8);
    backdrop-filter: blur(4px);
  }

  .video-overlay__card {
    position: fixed;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: min(90vw, 800px);
    max-height: 90vh;
    overflow-y: auto;
    background: var(--color-card, #1a1a2e);
    border: 1px solid var(--color-border, #2a2a4a);
    border-radius: 1rem;
    box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.5);
    display: flex;
    flex-direction: column;
  }

  .video-overlay__header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0.75rem 1rem;
    border-bottom: 1px solid var(--color-border, #2a2a4a);
  }

  .video-overlay__meta {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    flex-wrap: wrap;
    min-width: 0;
  }

  .video-overlay__username {
    font-weight: 600;
    font-size: 0.875rem;
    color: var(--color-text-primary, #e2e8f0);
  }

  .video-overlay__query {
    font-size: 0.75rem;
    font-weight: 500;
    padding: 0.125rem 0.5rem;
    border-radius: 0.375rem;
    background: var(--color-brand-subtle, rgba(168, 85, 247, 0.15));
    color: var(--color-brand, #a855f7);
  }

  .video-overlay__duration {
    font-size: 0.75rem;
    color: var(--color-text-muted, #64748b);
    font-variant-numeric: tabular-nums;
  }

  .video-overlay__close {
    flex-shrink: 0;
    width: 2rem;
    height: 2rem;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border-radius: 0.5rem;
    background: transparent;
    border: none;
    color: var(--color-text-secondary, #94a3b8);
    cursor: pointer;
    transition: background-color 0.15s, color 0.15s;
  }

  .video-overlay__close:hover {
    background: var(--color-card-hover, rgba(255, 255, 255, 0.05));
    color: var(--color-text-primary, #e2e8f0);
  }

  .video-overlay__video {
    width: 100%;
    display: block;
    background: #000;
    outline: none;
  }

  .video-overlay__text {
    padding: 0.75rem 1rem;
    font-size: 0.8125rem;
    line-height: 1.5;
    color: var(--color-text-secondary, #94a3b8);
    border-top: 1px solid var(--color-border, #2a2a4a);
    margin: 0;
  }

  .video-overlay__text:empty {
    display: none;
  }
</style>

<script>
  const dialog = document.getElementById("video-overlay") as HTMLDialogElement;
  const video = document.getElementById("overlay-video") as HTMLVideoElement;
  const usernameEl = document.getElementById("overlay-username")!;
  const queryEl = document.getElementById("overlay-query")!;
  const durationEl = document.getElementById("overlay-duration")!;
  const textEl = document.getElementById("overlay-text")!;
  const closeBtn = document.getElementById("overlay-close")!;

  function formatDuration(secs: number): string {
    if (secs >= 60) {
      const m = Math.floor(secs / 60);
      const s = Math.round(secs % 60);
      return s > 0 ? `${m}m ${s}s` : `${m}m`;
    }
    return `${Math.round(secs)}s`;
  }

  function openOverlay(data: {
    filename: string;
    username: string;
    query: string;
    text: string;
    duration: number;
  }) {
    usernameEl.textContent = data.username;
    queryEl.textContent = data.query;
    durationEl.textContent = formatDuration(data.duration);
    textEl.textContent = data.text || "";

    video.src = `/api/clips/${data.filename}`;
    dialog.showModal();
    video.play().catch(() => {});
  }

  function closeOverlay() {
    video.pause();
    video.removeAttribute("src");
    video.load();
    dialog.close();
  }

  // Listen for play button clicks (event delegation)
  document.addEventListener("click", (e) => {
    const btn = (e.target as Element).closest(".play-btn");
    if (!btn) return;

    const el = btn as HTMLElement;
    openOverlay({
      filename: el.dataset.filename!,
      username: el.dataset.username!,
      query: el.dataset.query!,
      text: el.dataset.text!,
      duration: parseFloat(el.dataset.duration!),
    });
  });

  closeBtn.addEventListener("click", closeOverlay);

  // Close on backdrop click
  dialog.addEventListener("click", (e) => {
    if (e.target === dialog) {
      closeOverlay();
    }
  });

  // Escape is handled natively by <dialog>, but we need to clean up video
  dialog.addEventListener("close", () => {
    video.pause();
    video.removeAttribute("src");
    video.load();
  });
</script>
