---
import { TOPIC_META, TOPIC_IDS } from "@/lib/topics";
import type { HeatmapRow } from "@/lib/db";

interface Props {
  data: HeatmapRow[];
}

const { data } = Astro.props;

// Build the matrix: group by session, then by topic
const sessionMap = new Map<number, { username: string; date: string; scores: Map<string, number> }>();

for (const row of data) {
  if (!sessionMap.has(row.session_id)) {
    sessionMap.set(row.session_id, {
      username: row.username,
      date: row.date,
      scores: new Map(),
    });
  }
  sessionMap.get(row.session_id)!.scores.set(row.topic, row.max_score);
}

const sessions = Array.from(sessionMap.entries()).map(([id, s]) => ({
  id,
  username: s.username,
  date: s.date.split("T")[0],
  scores: s.scores,
}));

// Min-max normalization across the entire matrix
const allScores = data.map((r) => r.max_score);
const globalMin = Math.min(...allScores);
const globalMax = Math.max(...allScores);
const globalRange = globalMax - globalMin;

function normalize(score: number): number {
  if (globalRange === 0) return 0.5;
  return (score - globalMin) / globalRange;
}

// CSS color → hex for opacity manipulation
const topicHexColors: Record<string, string> = {
  risas: "#fb923c",
  baile: "#f472b6",
  bromas: "#22d3ee",
  reflexion: "#34d399",
  guinos: "#a855f7",
  besos: "#f9a8d4",
};
---

{sessions.length > 0 ? (
  <div class="overflow-x-auto">
    <table class="heatmap-table">
      <thead>
        <tr>
          <th class="heatmap-corner"></th>
          {sessions.map((s) => (
            <th class="heatmap-col-header" title={`${s.username} — ${s.date}`}>
              <a href={`/sesiones/${s.id}`} class="hover:text-brand transition-colors">
                <span class="heatmap-username">{s.username.slice(0, 8)}</span>
                <span class="heatmap-date">{s.date.slice(5)}</span>
              </a>
            </th>
          ))}
        </tr>
      </thead>
      <tbody>
        {TOPIC_IDS.map((tid) => {
          const meta = TOPIC_META[tid];
          const hex = topicHexColors[tid] || "#888";
          return (
            <tr>
              <td class="heatmap-row-header">
                <span class="heatmap-dot" style={`background: ${hex};`} />
                {meta.label}
              </td>
              {sessions.map((s) => {
                const score = s.scores.get(tid);
                const norm = score != null ? normalize(score) : 0;
                const opacity = 0.1 + norm * 0.85;
                return (
                  <td
                    class="heatmap-cell"
                    style={`background: ${hex}; opacity: ${opacity.toFixed(2)};`}
                    title={`${meta.label} — ${s.username} ${s.date}\nScore: ${score?.toFixed(3) ?? "—"}`}
                  />
                );
              })}
            </tr>
          );
        })}
      </tbody>
    </table>
  </div>
) : (
  <p class="text-sm text-text-muted text-center py-6">Sin datos de heatmap disponibles.</p>
)}

<style>
  .heatmap-table {
    border-collapse: separate;
    border-spacing: 2px;
    width: 100%;
  }

  .heatmap-corner {
    width: 90px;
    min-width: 90px;
  }

  .heatmap-col-header {
    writing-mode: vertical-lr;
    text-orientation: mixed;
    transform: rotate(180deg);
    padding: 8px 2px;
    font-size: 0.65rem;
    font-weight: 500;
    color: var(--color-text-muted);
    text-align: left;
    white-space: nowrap;
    max-height: 100px;
    overflow: hidden;
  }

  .heatmap-col-header a {
    color: inherit;
    text-decoration: none;
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .heatmap-username {
    font-weight: 600;
    color: var(--color-text-secondary);
  }

  .heatmap-date {
    font-size: 0.6rem;
    opacity: 0.7;
  }

  .heatmap-row-header {
    font-size: 0.75rem;
    font-weight: 600;
    color: var(--color-text-secondary);
    padding: 4px 8px;
    white-space: nowrap;
    display: flex;
    align-items: center;
    gap: 6px;
  }

  .heatmap-dot {
    display: inline-block;
    width: 8px;
    height: 8px;
    border-radius: 50%;
    flex-shrink: 0;
  }

  .heatmap-cell {
    width: 28px;
    min-width: 28px;
    height: 28px;
    border-radius: 4px;
    cursor: default;
    transition: transform 0.1s ease;
  }

  .heatmap-cell:hover {
    transform: scale(1.3);
    z-index: 1;
  }
</style>
