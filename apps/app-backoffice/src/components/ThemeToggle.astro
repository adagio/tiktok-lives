---
interface Props {
  class?: string;
  showLabel?: boolean;
}

const { class: className = "", showLabel = false } = Astro.props;
---

<button
  data-theme-toggle
  aria-label="Cambiar tema"
  title="Cambiar tema"
  class:list={[
    "theme-toggle inline-flex items-center rounded-lg transition-colors cursor-pointer",
    "text-text-secondary hover:text-text-primary hover:bg-sidebar-hover",
    className,
  ]}
>
  <!-- Sun (shown in dark → click to go light) -->
  <svg class="theme-icon-sun w-[18px] h-[18px]" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
    <path d="M10 2a.75.75 0 01.75.75v1.5a.75.75 0 01-1.5 0v-1.5A.75.75 0 0110 2zM10 15a.75.75 0 01.75.75v1.5a.75.75 0 01-1.5 0v-1.5A.75.75 0 0110 15zM10 7a3 3 0 100 6 3 3 0 000-6zM15.657 5.404a.75.75 0 10-1.06-1.06l-1.061 1.06a.75.75 0 001.06 1.061l1.06-1.06zM6.464 14.596a.75.75 0 10-1.06-1.06l-1.061 1.06a.75.75 0 001.06 1.061l1.06-1.06zM18 10a.75.75 0 01-.75.75h-1.5a.75.75 0 010-1.5h1.5A.75.75 0 0118 10zM5 10a.75.75 0 01-.75.75h-1.5a.75.75 0 010-1.5h1.5A.75.75 0 015 10zM14.596 13.536a.75.75 0 011.06 1.06l-1.06 1.061a.75.75 0 11-1.06-1.06l1.06-1.061zM5.404 6.464a.75.75 0 011.06 1.06L5.404 8.586a.75.75 0 01-1.06-1.06l1.06-1.061z" />
  </svg>
  <!-- Moon (shown in light → click to go dark) -->
  <svg class="theme-icon-moon w-[18px] h-[18px]" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
    <path fill-rule="evenodd" d="M7.455 2.004a.75.75 0 01.26.77 7 7 0 009.958 7.967.75.75 0 011.067.853A8.5 8.5 0 116.647 1.921a.75.75 0 01.808.083z" clip-rule="evenodd" />
  </svg>
  {showLabel && <span class="theme-label-sun">Modo claro</span>}
  {showLabel && <span class="theme-label-moon">Modo oscuro</span>}
</button>

<style is:global>
  /* Dark: show sun icon + label */
  html.dark .theme-icon-moon, html.dark .theme-label-moon { display: none; }
  /* Light: show moon icon + label */
  html.light .theme-icon-sun, html.light .theme-label-sun { display: none; }
</style>
