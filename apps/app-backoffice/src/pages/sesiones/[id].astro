---
export const prerender = false;

import Layout from "@/layouts/Layout.astro";
import LocalTime from "@/components/LocalTime.astro";
import PlayButton from "@/components/PlayButton.astro";
import {
  getSession,
  getSessionBattles,
  getSessionChunks,
  getSessionClips,
  getSessionGuests,
  getSessionTopicScores,
  getSessionChatMessages,
  getLatestViewerJoin,
  isSessionActive,
  getChatAnalysis,
} from "@/lib/db";
import type { SessionDetail, ChunkRow, ClipRow, BattleRow, GuestRow, ChatMessageRow, ChatAnalysisRow } from "@/lib/db";
import { normalizeScores } from "@/lib/topics";
import type { TopicScore } from "@/lib/topics";

const id = Number(Astro.params.id);

if (isNaN(id)) {
  return Astro.redirect("/sesiones");
}

let session: SessionDetail | null = null;
let chunks: ChunkRow[] = [];
let clips: ClipRow[] = [];
let battles: BattleRow[] = [];
let guests: GuestRow[] = [];
let topics: TopicScore[] = [];
let chatMessages: ChatMessageRow[] = [];
let chatActive = false;
let chatAnalysis: { topics: string[]; summary: string } | null = null;
let latestJoin: { username: string; joined_at: string } | null = null;
let error: string | null = null;

try {
  session = await getSession(id);
  if (!session) {
    return Astro.redirect("/sesiones");
  }
  chunks = await getSessionChunks(id);
  clips = await getSessionClips(id);
  battles = await getSessionBattles(id);
  guests = await getSessionGuests(id);

  // Read chat messages (filter out legacy __join__ rows)
  try {
    chatMessages = (await getSessionChatMessages(id)).filter((m) => m.text !== "__join__");
    chatActive = await isSessionActive(id);
  } catch {
    // chat_messages table may not exist yet
  }
  latestJoin = await getLatestViewerJoin(id);

  // Chat analysis (LLM-generated topics + summary)
  try {
    const raw = await getChatAnalysis(id);
    if (raw) {
      chatAnalysis = { topics: JSON.parse(raw.topics), summary: raw.summary };
    }
  } catch {
    // chat_analysis table may not exist yet
  }

  // Read pre-computed topic scores
  try {
    const rawScores = await getSessionTopicScores(id);
    if (rawScores.length > 0) {
      topics = normalizeScores(
        rawScores.map((r) => ({ id: r.topic, rawScore: r.max_score })),
      );
    }
  } catch {
    // session_topics table may not exist yet
  }
} catch (e) {
  error = e instanceof Error ? e.message : "Error al cargar la sesión";
}

function formatDuration(seconds: number | null): string {
  if (seconds == null) return "—";
  const h = Math.floor(seconds / 3600);
  const m = Math.floor((seconds % 3600) / 60);
  const s = Math.floor(seconds % 60);
  if (h > 0) return s > 0 ? `${h}h ${m}m ${s}s` : m > 0 ? `${h}h ${m}m` : `${h}h`;
  return s > 0 ? `${m}m ${s}s` : `${m}m`;
}

function formatTime(seconds: number): string {
  const h = Math.floor(seconds / 3600);
  const m = Math.floor((seconds % 3600) / 60);
  const s = Math.floor(seconds % 60);
  if (h > 0) return `${h}:${String(m).padStart(2, "0")}:${String(s).padStart(2, "0")}`;
  return `${m}:${String(s).padStart(2, "0")}`;
}

function formatScore(score: number): string {
  return `${Math.round(score * 100)}%`;
}

function formatGuestDuration(joinedAt: string, leftAt: string | null): string | null {
  if (!leftAt) return null;
  const ms = new Date(leftAt).getTime() - new Date(joinedAt).getTime();
  if (isNaN(ms) || ms < 0) return null;
  const totalSecs = Math.floor(ms / 1000);
  const m = Math.floor(totalSecs / 60);
  const s = totalSecs % 60;
  if (m > 0) return s > 0 ? `${m}m ${s}s` : `${m}m`;
  return `${s}s`;
}

// Summary paragraphs from pre-generated summary
const summaryParagraphs = (session?.summary ?? "").split(/\n\n+/).filter((p: string) => p.trim());

const lastChatTimestamp = chatMessages.length > 0
  ? chatMessages[chatMessages.length - 1].timestamp
  : "";

const rawDate = session?.date;
const dateDisplay = rawDate instanceof Date ? rawDate.toISOString().split("T")[0] : rawDate?.split?.("T")[0] ?? "";
---

<Layout title={session ? `${session.username} — ${dateDisplay}` : "Sesión"}>
  {error ? (
    <div class="bg-error-subtle border border-error/20 rounded-xl p-6 text-center" role="alert">
      <p class="text-error font-medium mb-1">Error</p>
      <p class="text-error/70 text-sm">{error}</p>
      <a href="/sesiones" class="inline-block mt-3 text-sm text-error underline hover:no-underline">Volver</a>
    </div>
  ) : session && (
    <>
      {/* Header */}
      <div class="mb-8">
        <a href="/sesiones" class="text-sm text-text-muted hover:text-text-secondary transition-colors mb-3 inline-flex items-center gap-1">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 16 16" fill="currentColor" class="w-3.5 h-3.5" aria-hidden="true">
            <path fill-rule="evenodd" d="M9.78 4.22a.75.75 0 010 1.06L7.06 8l2.72 2.72a.75.75 0 11-1.06 1.06L5.47 8.53a.75.75 0 010-1.06l3.25-3.25a.75.75 0 011.06 0z" clip-rule="evenodd" />
          </svg>
          Sesiones
        </a>
        <div class="flex flex-wrap items-baseline gap-x-4 gap-y-1">
          <h1 class="text-2xl font-bold text-text-primary">{session.username}</h1>
          <LocalTime utc={session.date} fmt="datetime" class="text-text-secondary text-lg" />
        </div>
        <div class="flex flex-wrap items-center gap-4 mt-2 text-sm text-text-secondary">
          <span>{formatDuration(session.duration_seconds)}</span>
          <span>{chunks.length} chunks</span>
          <span>{clips.length} clips</span>
        </div>
      </div>

      {/* Tab bar */}
      <div class="flex gap-1 border-b border-border mb-6 overflow-x-auto" id="session-tabs">
        <button data-tab="general" class="session-tab active">
          General
        </button>
        <button data-tab="transcript" class="session-tab">
          Transcripción
          <span class="tab-badge">{chunks.length}</span>
        </button>
        <button data-tab="chat" class="session-tab">
          💬 Chat
          <span id="chat-count" class="tab-badge">{chatMessages.length}</span>
          {chatActive && (
            <span id="chat-live-badge" class="chat-live-badge">
              <span class="chat-live-dot" />
              EN VIVO
            </span>
          )}
        </button>
        <button data-tab="battles" class="session-tab">
          ⚔️ Batallas
          <span class="tab-badge">{battles.length}</span>
        </button>
        <button data-tab="ventanilla" class="session-tab">
          🎙️ Ventanilla
          <span class="tab-badge">{guests.length}</span>
        </button>
      </div>

      {/* ═══ Tab: General ═══ */}
      <div id="panel-general" class="tab-panel">
        <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
          <div class="lg:col-span-2 space-y-6">
            {/* Summary */}
            <section class="bg-card rounded-xl border border-border p-5">
              <h2 class="text-sm font-semibold text-text-primary uppercase tracking-wider mb-3">Resumen</h2>
              {summaryParagraphs.length > 0 ? (
                <div class="space-y-3">
                  {summaryParagraphs.map((p) => (
                    <p class="text-sm text-text-secondary leading-relaxed">{p}</p>
                  ))}
                </div>
              ) : (
                <p class="text-sm text-text-muted">Sin resumen disponible</p>
              )}
            </section>

            {/* Clips */}
            {clips.length > 0 && (
              <section class="bg-card rounded-xl border border-border p-5">
                <h2 class="text-sm font-semibold text-text-primary uppercase tracking-wider mb-3">
                  Clips <span class="text-text-muted font-normal normal-case">({clips.length})</span>
                </h2>
                <div class="space-y-2">
                  {clips.map((clip) => (
                    <div class="flex items-center gap-3 p-2 rounded-lg hover:bg-card-hover transition-colors">
                      <PlayButton
                        filename={clip.filename}
                        username={clip.username}
                        query={clip.query}
                        text={clip.text}
                        duration={clip.end_seconds - clip.start_seconds}
                      />
                      <div class="min-w-0 flex-1">
                        <div class="flex items-center gap-2">
                          <span class="inline-block bg-brand-subtle text-brand rounded-md px-1.5 py-0.5 text-xs font-medium">{clip.query}</span>
                          <span class="text-xs text-text-muted font-mono tabular-nums">{formatScore(clip.score)}</span>
                        </div>
                        <p class="text-xs text-text-secondary mt-0.5 truncate">{clip.text ?? "—"}</p>
                      </div>
                      <span class="text-xs text-text-muted tabular-nums whitespace-nowrap">
                        {formatTime(clip.start_seconds)}
                      </span>
                    </div>
                  ))}
                </div>
              </section>
            )}
          </div>

          <div class="space-y-6">
            {/* Topic Ranking */}
            <section class="bg-card rounded-xl border border-border p-5">
              <h2 class="text-sm font-semibold text-text-primary uppercase tracking-wider mb-4">Presencia de Topics</h2>
              {topics.length > 0 ? (
                <div class="space-y-3">
                  {topics.map((topic) => (
                    <div>
                      <div class="flex items-center justify-between mb-1">
                        <span class="text-sm font-medium text-text-primary">{topic.label}</span>
                        <span class="text-xs font-mono tabular-nums text-text-muted">{Math.round(topic.normalizedScore)}%</span>
                      </div>
                      <div class="h-2.5 rounded-full bg-surface-raised overflow-hidden">
                        <div
                          class="h-full rounded-full transition-all duration-500"
                          style={`width: ${Math.max(topic.normalizedScore, 3)}%; background: ${topic.color};`}
                        />
                      </div>
                    </div>
                  ))}
                </div>
              ) : (
                <p class="text-sm text-text-muted">Sin embeddings disponibles</p>
              )}
            </section>

            {/* Chat analysis summary (compact) */}
            {chatAnalysis && (
              <section class="bg-card rounded-xl border border-border p-5">
                <h2 class="text-sm font-semibold text-text-primary uppercase tracking-wider mb-3">Análisis de Chat</h2>
                <p class="text-sm text-text-secondary leading-relaxed mb-3">{chatAnalysis.summary}</p>
                <div class="flex flex-wrap gap-1.5">
                  {chatAnalysis.topics.map((topic) => (
                    <span class="inline-block text-xs font-medium px-2.5 py-1 rounded-full bg-brand-subtle text-brand border border-brand/20">
                      {topic}
                    </span>
                  ))}
                </div>
              </section>
            )}
          </div>
        </div>
      </div>

      {/* ═══ Tab: Transcripción ═══ */}
      <div id="panel-transcript" class="tab-panel hidden">
        <div class="bg-card rounded-xl border border-border">
          <div class="divide-y divide-border max-h-[75vh] overflow-y-auto">
            {chunks.map((chunk) => (
              <div class="px-5 py-3 hover:bg-card-hover transition-colors">
                <div class="flex items-start gap-3">
                  <span class="text-xs font-mono text-text-muted tabular-nums pt-0.5 w-14 shrink-0">
                    {formatTime(chunk.start_seconds)}
                  </span>
                  <p class="text-sm text-text-secondary leading-relaxed flex-1">{chunk.text}</p>
                </div>
              </div>
            ))}
            {chunks.length === 0 && (
              <div class="p-8 text-center text-text-muted">
                <p>Sin transcripción disponible para esta sesión</p>
              </div>
            )}
          </div>
        </div>
      </div>

      {/* ═══ Tab: Chat ═══ */}
      <div id="panel-chat" class="tab-panel hidden">
        <div class="bg-card rounded-xl border border-border">
          {chatAnalysis && (
            <div class="px-5 py-4 border-b border-border space-y-3">
              <p class="text-sm text-text-secondary leading-relaxed">{chatAnalysis.summary}</p>
              <div class="flex flex-wrap gap-1.5">
                {chatAnalysis.topics.map((topic) => (
                  <span class="inline-block text-xs font-medium px-2.5 py-1 rounded-full bg-brand-subtle text-brand border border-brand/20">
                    {topic}
                  </span>
                ))}
              </div>
            </div>
          )}

          <div id="chat-panel" class="max-h-[65vh] overflow-y-auto p-3 space-y-1 chat-panel">
            {chatMessages.length > 0 ? chatMessages.map((msg) => (
              <div class="chat-msg">
                <time data-utc={msg.timestamp instanceof Date ? msg.timestamp.toISOString() : msg.timestamp} data-fmt="time" class="chat-ts">{(msg.timestamp instanceof Date ? msg.timestamp.toISOString() : msg.timestamp).split("T")[1]?.slice(0, 5) ?? ""}</time>
                <span class="chat-user">{msg.username}</span>
                <span class="chat-text">{msg.text}</span>
              </div>
            )) : (
              <p class="text-sm text-text-muted text-center py-8">Sin mensajes de chat en esta sesión</p>
            )}
          </div>

          <div id="update-line" class="update-line">
            {latestJoin && (
              <span>👋 {latestJoin.username} se unió</span>
            )}
          </div>

          <div id="session-chat-data" class="hidden"
            data-session-id={id}
            data-active={chatActive ? "true" : "false"}
            data-last-ts={lastChatTimestamp}
          />
        </div>
      </div>

      {/* ═══ Tab: Batallas ═══ */}
      <div id="panel-battles" class="tab-panel hidden">
        <div class="bg-card rounded-xl border border-border p-5">
          {battles.length > 0 ? (
            <div class="space-y-3">
              {battles.map((b) => {
                const won = b.host_score > b.opponent_score;
                const lost = b.host_score < b.opponent_score;
                const draw = b.host_score === b.opponent_score && (b.host_score > 0 || b.opponent_score > 0);
                const resultLabel = won ? "W" : lost ? "L" : draw ? "D" : "";
                const resultColor = won
                  ? "text-emerald-400 bg-emerald-500/15 border-emerald-500/30"
                  : lost
                    ? "text-rose-400 bg-rose-500/15 border-rose-500/30"
                    : "text-amber-400 bg-amber-500/15 border-amber-500/30";
                const detectedAt = b.detected_at;
                return (
                  <a href={`/batallas/${b.id}`} class="flex items-center gap-3 p-3 rounded-lg bg-surface-raised/50 border border-border/50 hover:border-brand/30 transition-colors">
                    {resultLabel && (
                      <span class={`shrink-0 w-8 h-8 rounded-lg flex items-center justify-center text-xs font-bold border ${resultColor}`}>
                        {resultLabel}
                      </span>
                    )}
                    <div class="min-w-0 flex-1">
                      <span class="text-sm font-semibold text-text-primary">@{b.opponent_username}</span>
                      <div class="flex items-center gap-2 mt-0.5">
                        <span class="text-xs font-mono tabular-nums text-text-secondary">
                          {b.host_score} — {b.opponent_score}
                        </span>
                        {detectedAt && (
                          <LocalTime utc={detectedAt} fmt="time" class="text-xs text-text-muted" />
                        )}
                      </div>
                    </div>
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 16 16" fill="currentColor" class="w-4 h-4 text-text-muted shrink-0" aria-hidden="true">
                      <path fill-rule="evenodd" d="M6.22 4.22a.75.75 0 011.06 0l3.25 3.25a.75.75 0 010 1.06l-3.25 3.25a.75.75 0 01-1.06-1.06L8.94 8 6.22 5.28a.75.75 0 010-1.06z" clip-rule="evenodd" />
                    </svg>
                  </a>
                );
              })}
            </div>
          ) : (
            <p class="text-sm text-text-muted text-center py-8">Sin batallas detectadas en esta sesión</p>
          )}
        </div>
      </div>

      {/* ═══ Tab: Ventanilla ═══ */}
      <div id="panel-ventanilla" class="tab-panel hidden">
        <div class="bg-card rounded-xl border border-border p-5">
          {guests.length > 0 ? (
            <div class="space-y-3">
              {guests.map((g) => {
                const isLive = !g.left_at;
                const duration = formatGuestDuration(g.joined_at, g.left_at);
                const joinedAt = g.joined_at;
                return (
                  <div class="flex items-center gap-3 p-3 rounded-lg bg-surface-raised/50 border border-border/50 hover:border-border transition-colors">
                    {isLive && (
                      <span class="shrink-0 relative flex h-2.5 w-2.5">
                        <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-emerald-400 opacity-75"></span>
                        <span class="relative inline-flex rounded-full h-2.5 w-2.5 bg-emerald-500"></span>
                      </span>
                    )}
                    <div class="min-w-0 flex-1">
                      <span class="text-sm font-semibold text-text-primary">@{g.username}</span>
                      <div class="flex items-center gap-2 mt-0.5">
                        {joinedAt && (
                          <LocalTime utc={joinedAt} fmt="time" class="text-xs text-text-muted" />
                        )}
                        {isLive ? (
                          <span class="text-xs font-medium text-emerald-400">en vivo</span>
                        ) : duration && (
                          <span class="text-xs text-text-muted font-mono tabular-nums">{duration}</span>
                        )}
                      </div>
                    </div>
                  </div>
                );
              })}
            </div>
          ) : (
            <p class="text-sm text-text-muted text-center py-8">Sin invitados en esta sesión</p>
          )}
        </div>
      </div>
    </>
  )}
</Layout>

<style>
  .session-tab {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 10px 18px;
    font-size: 0.8rem;
    font-weight: 600;
    letter-spacing: 0.03em;
    color: var(--color-text-muted);
    border: none;
    border-bottom: 2px solid transparent;
    margin-bottom: -1px;
    cursor: pointer;
    background: none;
    white-space: nowrap;
    transition: color 0.15s, border-color 0.15s;
  }

  .session-tab:hover {
    color: var(--color-text-secondary);
  }

  .session-tab.active {
    color: var(--color-text-primary);
    border-bottom-color: var(--color-brand);
  }

  .tab-badge {
    font-size: 0.7rem;
    font-weight: 500;
    color: var(--color-text-muted);
    background: var(--color-surface-raised);
    padding: 1px 7px;
    border-radius: 9999px;
  }

  .session-tab.active .tab-badge {
    background: var(--color-brand-subtle);
    color: var(--color-brand);
  }

  .tab-panel.hidden {
    display: none;
  }

  .chat-live-badge {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 2px 10px;
    border-radius: 9999px;
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    color: #f87171;
    background: rgba(248, 113, 113, 0.12);
    border: 1px solid rgba(248, 113, 113, 0.25);
  }

  .chat-live-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: #f87171;
    animation: pulse-dot 1.5s ease-in-out infinite;
  }

  @keyframes pulse-dot {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.3; }
  }

  .chat-panel {
    min-height: 200px;
  }

  .update-line {
    padding: 6px 12px;
    font-size: 0.75rem;
    color: var(--color-text-muted);
    border-top: 1px solid var(--color-border);
    height: 30px;
    display: flex;
    align-items: center;
    opacity: 0.7;
  }
</style>

<style is:global>
  #chat-panel .chat-msg {
    display: flex;
    align-items: baseline;
    gap: 6px;
    padding: 2px 4px;
    border-radius: 4px;
    font-size: 0.8rem;
    line-height: 1.4;
  }

  #chat-panel .chat-msg:hover {
    background: var(--color-card-hover);
  }

  #chat-panel .chat-ts {
    flex-shrink: 0;
    font-size: 0.65rem;
    font-variant-numeric: tabular-nums;
    color: var(--color-text-muted);
    opacity: 0.6;
  }

  #chat-panel .chat-user {
    flex-shrink: 0;
    font-weight: 600;
    color: var(--color-accent-cyan);
    font-size: 0.75rem;
  }

  #chat-panel .chat-text {
    color: var(--color-text-secondary);
    word-break: break-word;
  }

  #chat-panel .chat-msg-new {
    animation: msg-fade-in 0.3s ease-out;
  }

  @keyframes msg-fade-in {
    from { opacity: 0; transform: translateY(4px); }
    to { opacity: 1; transform: translateY(0); }
  }
</style>

<script is:inline>
(function() {
  var tabs = document.querySelectorAll('.session-tab');
  tabs.forEach(function(tab) {
    tab.addEventListener('click', function() {
      var target = tab.dataset.tab;
      tabs.forEach(function(t) { t.classList.remove('active'); });
      tab.classList.add('active');
      document.querySelectorAll('.tab-panel').forEach(function(p) { p.classList.add('hidden'); });
      var panel = document.getElementById('panel-' + target);
      if (panel) panel.classList.remove('hidden');
      if (target === 'chat') {
        var chatPanel = document.getElementById('chat-panel');
        if (chatPanel) chatPanel.scrollTop = chatPanel.scrollHeight;
      }
    });
  });
})();
</script>

<script is:inline>
(function() {
  var el = document.getElementById('session-chat-data');
  if (!el) return;

  var sessionId = el.dataset.sessionId;
  var lastTs = el.dataset.lastTs || '';
  var msgCount = document.querySelectorAll('#chat-panel .chat-msg').length;

  function isNearBottom(p) {
    if (!p) return true;
    return p.scrollHeight - p.scrollTop - p.clientHeight < 60;
  }

  function scrollToBottom(p) {
    if (p) p.scrollTop = p.scrollHeight;
  }

  scrollToBottom(document.getElementById('chat-panel'));

  var timeFmt = new Intl.DateTimeFormat(undefined, { hour: '2-digit', minute: '2-digit' });

  function appendMsg(msg) {
    var panel = document.getElementById('chat-panel');
    if (!panel) return;
    if (msg.text === '__join__') return; // legacy rows — skip

    var div = document.createElement('div');
    div.className = 'chat-msg chat-msg-new';

    var ts = document.createElement('time');
    ts.className = 'chat-ts';
    var d = new Date(msg.timestamp.includes('+') || msg.timestamp.includes('Z') ? msg.timestamp : msg.timestamp + 'Z');
    ts.textContent = timeFmt.format(d);
    ts.setAttribute('data-utc', msg.timestamp);
    ts.setAttribute('data-fmt', 'time');

    var user = document.createElement('span');
    user.className = 'chat-user';
    user.textContent = msg.username;

    var text = document.createElement('span');
    text.className = 'chat-text';
    text.textContent = msg.text;

    div.appendChild(ts);
    div.appendChild(user);
    div.appendChild(text);

    // Remove empty state if present
    var empty = panel.querySelector('p.text-sm');
    if (empty) empty.remove();

    panel.appendChild(div);
  }

  async function pollMessages() {
    try {
      var url = '/api/session/' + sessionId + '/messages';
      if (lastTs) url += '?since=' + encodeURIComponent(lastTs);
      var res = await fetch(url);
      if (!res.ok) return;
      var data = await res.json();

      var panel = document.getElementById('chat-panel');

      if (data.messages && data.messages.length > 0) {
        var nearBottom = isNearBottom(panel);

        for (var i = 0; i < data.messages.length; i++) {
          appendMsg(data.messages[i]);
          lastTs = data.messages[i].timestamp;
          msgCount++;
        }

        var countEl = document.getElementById('chat-count');
        if (countEl) countEl.textContent = '(' + msgCount + ' mensajes)';
        if (nearBottom) scrollToBottom(panel);
      }

      // Update status line with latest join
      var updateLine = document.getElementById('update-line');
      if (data.last_join && updateLine) {
        updateLine.textContent = '\uD83D\uDC4B ' + data.last_join.username + ' se unió';
      }

      var liveBadge = document.getElementById('chat-live-badge');
      if (liveBadge) {
        liveBadge.style.display = data.is_active ? '' : 'none';
      }
    } catch(e) {
      // Silently ignore fetch errors
    }
  }

  setInterval(pollMessages, 3000);

  // Fetch immediately when tab regains focus (browsers throttle setInterval in background tabs)
  document.addEventListener('visibilitychange', function() {
    if (!document.hidden) pollMessages();
  });
})();
</script>
