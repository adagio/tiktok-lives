---
export const prerender = false;

import Layout from "@/layouts/Layout.astro";
import LocalTime from "@/components/LocalTime.astro";
import { getDayDetail } from "@/lib/db";

const day = Astro.params.day;

if (!day) {
  return Astro.redirect("/dias");
}

const sessions = await getDayDetail(day);

if (sessions.length === 0) {
  return Astro.redirect("/dias");
}

// Group by author
const byAuthor = new Map<string, typeof sessions>();
for (const s of sessions) {
  const list = byAuthor.get(s.username) || [];
  list.push(s);
  byAuthor.set(s.username, list);
}

function formatDuration(seconds: number | null): string {
  if (seconds == null) return "";
  const h = Math.floor(seconds / 3600);
  const m = Math.floor((seconds % 3600) / 60);
  if (h > 0) return m > 0 ? `${h}h ${m}m` : `${h}h`;
  return `${m}m`;
}

const totalDuration = sessions.reduce((acc, s) => acc + (s.duration_seconds ?? 0), 0);
const totalMessages = sessions.reduce((acc, s) => acc + s.chat_message_count, 0);
---

<Layout title={`${day} — Dia`}>
  <div class="mb-8">
    <a href="/dias" class="text-sm text-text-muted hover:text-text-secondary transition-colors mb-3 inline-flex items-center gap-1">
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 16 16" fill="currentColor" class="w-3.5 h-3.5" aria-hidden="true">
        <path fill-rule="evenodd" d="M9.78 4.22a.75.75 0 010 1.06L7.06 8l2.72 2.72a.75.75 0 11-1.06 1.06L5.47 8.53a.75.75 0 010-1.06l3.25-3.25a.75.75 0 011.06 0z" clip-rule="evenodd" />
      </svg>
      Dias
    </a>
    <h1 class="text-2xl font-bold text-text-primary">{day}</h1>
    <div class="flex flex-wrap items-center gap-4 mt-2 text-sm text-text-secondary">
      <span>{sessions.length} sesion{sessions.length !== 1 ? "es" : ""}</span>
      <span>{formatDuration(totalDuration)}</span>
      <span>{totalMessages.toLocaleString()} mensajes de chat</span>
    </div>
  </div>

  <div class="space-y-8">
    {[...byAuthor.entries()].map(([author, authorSessions]) => (
      <section>
        <h2 class="text-lg font-bold text-text-primary mb-4">
          <a href={`/autores/${author}`} class="hover:text-brand transition-colors">@{author}</a>
        </h2>

        <div class="space-y-4">
          {authorSessions.map((s) => (
            <div class="bg-card rounded-xl border border-border p-5">
              <div class="flex items-center justify-between mb-3">
                <a href={`/sesiones/${s.session_id}`} class="text-sm font-semibold text-brand hover:underline">
                  <LocalTime utc={s.date} fmt="time" />
                  {s.duration_seconds ? ` (${formatDuration(s.duration_seconds)})` : ""}
                </a>
                <div class="flex items-center gap-3 text-xs text-text-muted">
                  {s.battle_count > 0 && <span>{s.battle_count} batalla{s.battle_count !== 1 ? "s" : ""}</span>}
                  {s.guest_count > 0 && <span>{s.guest_count} guest{s.guest_count !== 1 ? "s" : ""}</span>}
                  {s.chat_message_count > 0 && <span>{s.chat_message_count.toLocaleString()} msgs</span>}
                  {s.chunk_count > 0 && <span>{s.chunk_count} chunks</span>}
                </div>
              </div>

              {/* Transcript summary */}
              {s.summary && (
                <div class="mb-3">
                  <p class="text-xs font-semibold text-text-muted uppercase tracking-wider mb-1">Resumen del live</p>
                  <p class="text-sm text-text-secondary leading-relaxed">{s.summary.split("\n\n")[0]}</p>
                </div>
              )}

              {/* Chat summary + topics */}
              {s.chat_summary && (
                <div>
                  <p class="text-xs font-semibold text-text-muted uppercase tracking-wider mb-1">Chat de audiencia</p>
                  <p class="text-sm text-text-secondary leading-relaxed mb-2">{s.chat_summary}</p>
                  {s.chat_topics && (
                    <div class="flex flex-wrap gap-1.5">
                      {(JSON.parse(s.chat_topics) as string[]).map((topic: string) => (
                        <span class="inline-block text-xs px-2 py-0.5 rounded-full bg-surface-raised text-text-secondary">
                          {topic}
                        </span>
                      ))}
                    </div>
                  )}
                </div>
              )}

              {/* Empty state */}
              {!s.summary && !s.chat_summary && (
                <p class="text-sm text-text-muted">Sin resumen disponible</p>
              )}
            </div>
          ))}
        </div>
      </section>
    ))}
  </div>
</Layout>
